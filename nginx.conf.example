# Example nginx config for serving the built Angular app and proxying the API.
#
# The single `/api/` location handles BOTH:
#   - REST calls    -> /api/game/...        (HttpClient, environment.apiUrl)
#   - Socket.IO      -> /api/socket.io/...   (presence.service.ts `path`)
# because the gateway's Socket.IO endpoint was moved under /api/socket.io
# (see backend/src/game/game.gateway.ts). The upgrade headers below are what
# let the WebSocket handshake succeed; without them Socket.IO is stuck on
# HTTP long-polling or fails outright.
#
# `backend` here is the service/host name of the NestJS container (e.g. the
# service name in docker-compose). Adjust the upstream host:port as needed.

upstream backend {
    server backend:3000;
}

# Sets $connection_upgrade to "upgrade" for WebSocket requests and "close"
# otherwise, so normal REST calls aren't sent a bogus upgrade header. This is an
# http-context directive: in a typical image it lives in a file under
# /etc/nginx/conf.d/, which nginx includes inside its `http { }` block.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name _;

    # --- Static Angular app ---
    root /usr/share/nginx/html;
    index index.html;

    # SPA fallback: unknown routes return index.html so Angular's router handles
    # them client-side.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # --- API + WebSocket, all under the /api prefix ---
    location /api/ {
        proxy_pass http://backend;

        # Forward the original host/scheme/client info to the backend.
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket upgrade — required for the Socket.IO connection on
        # /api/socket.io to switch from polling to a real WebSocket.
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Long-lived sockets shouldn't be killed by a short read timeout.
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
